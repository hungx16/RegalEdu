
@model RegalEdu.Application.Common.Request.ForgotPasswordRequest
@{
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Your New Password</title>
</head>
<body>
    <p>Hello @Model.UserName,</p>

    <p>Your password has been successfully reset.</p>

    <p>Your new password is:</p>

    <p style="font-size: 18px; font-weight: bold; color: #2e6da4;">@Model.Password</p>

    <p>Please log in and change your password immediately after logging in.</p>

    <p>Best regards,<br />RegalEdu Team</p>
</body>
</html>