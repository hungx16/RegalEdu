
@model RegalEdu.Application.Common.Request.ForgotPasswordRequest
@{
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Mật khẩu mới của bạn</title>
</head>
<body>
    <p>Xin chào @Model.UserName,</p>

    <p>Mật khẩu của bạn đã được đặt lại thành công.</p>

    <p>Mật khẩu mới của bạn là:</p>

    <p style="font-size: 18px; font-weight: bold; color: #2e6da4;">@Model.Password</p>

    <p>Vui lòng đăng nhập và thay đổi mật khẩu ngay sau khi đăng nhập.</p>

    <p>Trân trọng,<br />Đội ngũ RegalEdu</p>
</body>
</html>